<project name="FootballPlayers" default="compile">
    <target name="compile">
        <mkdir dir="build"/>
        <javac srcdir="src" destdir="build" includeantruntime="false"/>
    </target>

    <target name="run" depends="compile">
        <java classname="View.Main" fork="true">
            <classpath>
                <pathelement location="build"/>
            </classpath>
        </java>
    </target>
</project>
